<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Movies.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/colorSearchBar</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorTextMuted</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="android:textColorHint">@color/colorTextMuted</item>
        <item name="endIconTint">@color/colorTextMuted</item>
    </style>

    <style name="Widget.Movies.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.Movies.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/colorStroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="TextAppearance.Movies.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Movies.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Movies.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/colorBottomNav</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Movies.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/colorSurfaceLight</item>
        <item name="chipStrokeColor">@color/colorStroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>
</resources>
